{
  "name": "spikequiz",
  "private": true,
  "packageManager": "bun@1.3.6",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "all": " bun fmt && bun lint && bun typecheck && bun test ",
    "test": "turbo run test",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "fmt": "biome format --write .",
    "typecheck": "turbo run typecheck",
    "glm": "ollama launch claude --model glm-5:cloud",
    "pr": "bun scripts/fetch-pr-review.ts",
    "logs:deployment": "bash scripts/deployment-logs.sh"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.7",
    "@types/bun": "^1.3.10",
    "turbo": "^2.8.17",
    "typescript": "^5.9.3"
  }
}
